# Local configuration — contains database credentials.
# Copy config/config.example.php to config/config.php on each machine.
config/config.php

# Uploaded profile photos are user data, not source.
public/uploads/*
!public/uploads/.gitkeep

# Logs and caches
storage/logs/*
!storage/logs/.gitkeep
*.log

# Dependency directories (none required, but keep them out if added later)
/vendor/
/node_modules/

